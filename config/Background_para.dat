# --- 幾何設定 (Geometry Settings) ---
GEOM_FILE geometries/L-shape_dense.dat

# --- 計算域邊界 (Domain Boundaries) ---
DOMAIN_X_MIN -5.0
DOMAIN_X_MAX 5.0
DOMAIN_Y_MIN -5.0
DOMAIN_Y_MAX 5.0

# --- 網格尺寸設定 (Mesh Size Settings) ---
SURFACE_MESH_SIZE 0.2
FARFIELD_MESH_SIZE 1.0

# --- 邊界層設定 (Boundary Layer - Phase 3) ---
BL_INITIAL_THICKNESS 0.002
BL_GROWTH_RATE 1.2
BL_LAYERS 8
BL_FAN_NODES 5
BL_AUTO_FAN_NODES 1
BL_FAN_ANGLE_THRESHOLD 60.0
BL_SMOOTHING_ITERS 0
BL_MERGE_CONCAVE 0

# --- Method 5 Settings ---
BL_CONCAVE_METHOD 5
BL_CONCAVE_INFLUENCE_MULTIPLIER 2.0

BL_CONVEX_ANGLE_THRESHOLD 260.0
BL_CONCAVE_ANGLE_THRESHOLD 100.0

# --- 過渡層設定 (Transition Layer - Phase 4) ---
BL_TRANSITION_LAYERS 10
BL_AUTO_TRANSITION_LAYERS 1
BL_TRANSITION_GROWTH_RATE 1.15

# --- Gmsh 底層演算法設定 (Gmsh Advanced Settings) ---
GMSH_ALGORITHM 6
GMSH_OPTIMIZE 1
FARFIELD_GROWTH_RATE 0.1
