{
  "elements": [
    {
      "name": "High_Res_Airfoil",
      "input_file": "examples/geometries/naca0012.dat",
      "output_file": "Results/pro_airfoil.dat",
      "is_closed": true,
      "transform": { "scale": 2.0, "rotate": 10.0, "translate": [0, 0] },
      "segments": [
        {
          "id": 1,
          "comment": "上翼面",
          "start_index": 0, "end_index": 80,
          "strategy": "uniform",
          "parameters": { "spacing": 0.02 }
        },
        {
          "id": 2,
          "comment": "前緣區域：使用 Cosine 雙端加密，確保最前端點極密",
          "start_index": 80, "end_index": 120,
          "strategy": "cosine",
          "parameters": { "n_points": 60 }
        },
        {
          "id": 3,
          "comment": "下翼面",
          "start_index": 120, "end_index": -1,
          "strategy": "uniform",
          "parameters": { "spacing": 0.02 }
        }
      ]
    },
    {
      "name": "Parametric_Control_Surface",
      "output_file": "Results/pro_control.dat",
      "is_closed": true,
      "segments": [
        {
          "id": 1,
          "type": "curve",
          "x_formula": "0.5 * cos(t) + 3.0",
          "y_formula": "0.2 * sin(t)",
          "parameters": { "range": [0, 6.28318], "spacing": 0.02 }
        }
      ]
    }
  ]
}
